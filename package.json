{
  "name": "tibis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main/index.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:build-main": "tsc -p electron/tsconfig.json",
    "electron:watch-main": "tsc -p electron/tsconfig.json -w",
    "electron:run": "wait-on dist-electron/main/index.mjs && node --watch-path=dist-electron --watch-preserve-output ./node_modules/electron/cli.js .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron:watch-main\" \"npm run electron:run\"",
    "electron:build": "npm run build && npm run electron:build-main && electron-builder",
    "start:windows": "npm run electron:dev",
    "postinstall": "electron-rebuild",
    "lint": "eslint src --ext .vue,.ts,.tsx,.js,.jsx --fix",
    "lint:style": "stylelint 'src/**/*.{vue,less,css}' --fix"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.67",
