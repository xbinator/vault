{
  "name": "tibis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist-electron/main/index.mjs",
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev": "concurrently -k \"pnpm run serve\" \"pnpm run electron:watch-main\" \"pnpm run electron:run\"",
    "electron:dev": "pnpm run dev",
    "electron:build-main": "tsc -p electron/tsconfig.json",
    "electron:watch-main": "tsc -p electron/tsconfig.json -w",
    "electron:run": "wait-on dist-electron/main/index.mjs && node --watch-path=dist-electron --watch-preserve-output ./node_modules/electron/cli.js .",
    "electron:build": "pnpm run build && pnpm run electron:build-main && electron-builder",
    "postinstall": "electron-rebuild",
    "test": "cross-env HOST=127.0.0.1 vitest run",
    "speech:dev:prepare": "node ./scripts/speech/dev-runtime.mjs prepare",
    "speech:dev:serve": "node ./scripts/speech/dev-runtime.mjs serve",
    "speech:dev:start": "concurrently -k \"pnpm run speech:dev:serve\" \"cross-env TIBIS_SPEECH_RUNTIME_MANIFEST_URL=http://127.0.0.1:8787/manifest.json pnpm dev\"",
    "speech:manifest:fill": "node ./scripts/speech/manifest-tool.mjs fill",
    "speech:manifest:hash": "node ./scripts/speech/manifest-tool.mjs hash",
    "speech:manifest:localize": "node ./scripts/speech/manifest-tool.mjs localize",
    "speech:manifest:validate": "node ./scripts/speech/manifest-tool.mjs validate",
    "lint": "eslint src --ext .vue,.ts,.tsx,.js,.jsx --fix",
    "lint:style": "stylelint 'src/**/*.{vue,less,css}' --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/openai": "^3.0.63",
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.5",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@iconify/vue": "^5.0.1",
    "@lezer/highlight": "^1.2.3",
    "@tavily/ai-sdk": "^0.5.0",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-bubble-menu": "^3.23.4",
    "@tiptap/extension-code": "^3.23.4",
    "@tiptap/extension-code-block-lowlight": "^3.23.4",
    "@tiptap/extension-color": "^3.23.4",
