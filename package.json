    "@tiptap/starter-kit": "^3.23.4",
    "@tiptap/vue-3": "^3.23.4",
    "@vueuse/core": "^14.3.0",
    "ai": "^6.0.182",
    "ant-design-vue": "^4.2.6",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "dayjs": "^1.11.20",
    "electron-log": "^5.4.4",
    "electron-store": "^10.1.0",
    "js-beautify": "^1.15.4",
