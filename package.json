    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-list": "^3.23.4",
    "@tiptap/extension-mathematics": "^3.23.4",
    "@tiptap/extension-paragraph": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
