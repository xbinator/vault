    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.1.1",
